{
  "name": "open-agent",
  "version": "1.0.0",
  "description": "OpenCode Plugin with Named Agent System - Sisyphus, Atlas, Prometheus orchestration with Validator workflow",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "bin": {
    "open-agent": "bin/open-agent.js"
  },
  "files": [
    "dist",
    "bin",
    ".opencode"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target bun --format esm --external @ast-grep/napi && tsc --emitDeclarationOnly",
    "clean": "rm -rf dist",
    "prepare": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "agents",
    "sisyphus",
    "atlas",
    "prometheus",
    "ai",
    "llm"
  ],
  "author": "OpenCode",
  "license": "SUL-1.0",
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@opencode-ai/sdk": "^1.4.0",
    "zod": "^4.3.0"
  },
  "devDependencies": {
    "bun-types": "1.3.11",
    "typescript": "^5.7.3"
  }
}